FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml .
RUN pip install --no-cache-dir .

COPY backend/ ./backend/

# Pre-built model artifacts and processed data are expected to exist
# in the build context (produced by the DVC pipeline before docker build)
COPY models/ ./models/
COPY data/cleaned_data.csv \
     data/collab_filtered_data.csv \
     data/track_ids.npy \
     ./data/

EXPOSE 8000
CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
